{
  "kind": "collectionType",
  "collectionName": "homes",
  "info": {
    "singularName": "home",
    "pluralName": "homes",
    "displayName": "Home"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "default": "care-home",
      "enum": [
        "care-home",
        "supported-home"
      ]
    },
    "name": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "address": {
      "type": "string",
      "required": true
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "facebook": {
      "type": "string",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "type"
            },
            "care-home"
          ]
        }
      },
      "required": true
    },
    "carehome_review": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "type"
            },
            "care-home"
          ]
        }
      },
      "component": "shared.carehome-widget",
      "repeatable": false,
      "required": true
    },
    "cqc_rating": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "type"
            },
            "care-home"
          ]
        }
      },
      "component": "shared.cqc-widget",
      "repeatable": false,
      "required": true
    },
    "tagline": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "location": {
      "type": "component",
      "component": "shared.location",
      "repeatable": false,
      "required": true
    },
    "why_choose_us": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "type"
            },
            "care-home"
          ]
        }
      },
      "component": "shared.cards",
      "repeatable": true
    },
    "what_we_offer": {
      "type": "component",
      "component": "shared.what-we-offer",
      "repeatable": false
    },
    "spaces": {
      "type": "component",
      "component": "shared.spaces",
      "repeatable": true
    },
    "facilities": {
      "type": "component",
      "component": "shared.facilities",
      "repeatable": false
    },
    "reviews": {
      "type": "component",
      "component": "shared.reviews",
      "repeatable": true
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "thumbnails": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "brochure": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "team": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::team.team",
      "mappedBy": "home"
    },
    "meet_our_team": {
      "type": "component",
      "component": "shared.meet-our-team",
      "repeatable": false
    },
    "gallery": {
      "type": "media",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "type"
            },
            "care-home"
          ]
        }
      },
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
