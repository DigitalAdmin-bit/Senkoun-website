{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "blocks"
    },
    "date": {
      "type": "component",
      "component": "shared.date-range",
      "repeatable": false
    },
    "home": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::home.home"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "expires_at": {
      "type": "datetime"
    }
  }
}
