{
  "kind": "collectionType",
  "collectionName": "jobs",
  "info": {
    "singularName": "job",
    "pluralName": "jobs",
    "displayName": "Job"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "blocks"
    },
    "salary": {
      "type": "component",
      "component": "shared.salary",
      "repeatable": false
    },
    "tags": {
      "type": "component",
      "component": "shared.tags",
      "repeatable": true
    },
    "job_type": {
      "type": "enumeration",
      "enum": [
        "full time",
        "part time",
        "internship",
        "contract",
        "freelance",
        "temporary"
      ]
    },
    "work_type": {
      "type": "enumeration",
      "enum": [
        "on site",
        "remote",
        "hybrid"
      ]
    },
    "home": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::home.home"
    },
    "questions": {
      "type": "component",
      "component": "shared.questions",
      "repeatable": true
    },
    "open": {
      "type": "boolean",
      "required": true,
      "default": true
    }
  }
}
